# Supabase Configuration
# Get these values from your Supabase project dashboard

SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_publishable_key"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.eyJ..."  # Service role key (keep secret!)
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_DB_PASSWORD="your-db-password"
SUPABASE_ACCESS_TOKEN="sbp_your_access_token"

# Vite client-side variables (must start with VITE_)
VITE_SUPABASE_URL="${SUPABASE_URL}"
VITE_SUPABASE_PUBLISHABLE_KEY="${SUPABASE_PUBLISHABLE_KEY}"
VITE_SUPABASE_PROJECT_ID="${SUPABASE_PROJECT_ID}"
